# Copy to .env and edit locally. Do not commit .env.

KEYCLOAK_NAMESPACE=keycloak
KEYCLOAK_NAME=openclaw-keycloak
KEYCLOAK_REALM=agentic
KEYCLOAK_CLIENT_ID=vault
KEYCLOAK_GROUP=vault-users

VAULT_NAMESPACE=vault
VAULT_ADDR=https://vault.apps.example.com
VAULT_KV_MOUNT=users
VAULT_OIDC_MOUNT=oidc
VAULT_OIDC_ROLE=default

# Set from a local shell or secret manager before running scripts.
# VAULT_TOKEN=
# KEYCLOAK_VAULT_CLIENT_SECRET=
